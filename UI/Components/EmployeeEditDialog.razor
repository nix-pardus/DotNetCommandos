@using UI.Models
@using UI.Models.Employees
@using UI.Services
@inject IEmployeeService EmployeeService
@inject INotificationService NotificationService

<MudDialog>
	<DialogContent>
		<EditForm Model="@(IsEdit ? (object)EditEmployee : CreateEmployee)" OnInvalidSubmit="Save" @ref="editForm">
			<DataAnnotationsValidator/>
			<ValidationSummary class="mud-error-text"/>
			<MudGrid>
				@if (IsEdit)
				{
					<MudItem xs="12" sm="6">
						<MudTextField @bind-Value="EditEmployee!.LastName" Label="Фамилия" Required For="@(() => EditEmployee!.LastName)" />
					</MudItem>
					<MudItem xs="12" sm="6">
						<MudTextField @bind-Value="EditEmployee!.Name" Label="Имя" Required For="@(() => EditEmployee!.Name)" />
					</MudItem>
					<MudItem xs="12" sm="6">
						<MudTextField @bind-Value="EditEmployee!.Patronymic" Label="Отчество" />
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="EditEmployee!.Email" Label="Email" Required For="@(() => EditEmployee!.Email)" />
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="EditEmployee!.PhoneNumber" Label="Номер телефона" Required For="@(() => EditEmployee!.PhoneNumber)" />
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="EditEmployee!.Address" Label="Адрес" Lines="2" Required For="@(() => EditEmployee!.Address)" />
					</MudItem>
					<MudItem xs="12">
						<MudSelect T="RoleType" @bind-Value="EditEmployee!.Role" Label="Роль" Required For="@(() => EditEmployee!.Role)" >
							@foreach (var role in Enum.GetValues<RoleType>())
							{
								<MudSelectItem Value="role">@role</MudSelectItem>
							}
						</MudSelect>
					</MudItem>
				}
				else
				{
					<MudItem xs="12" sm="6">
						<MudTextField @bind-Value="CreateEmployee!.LastName" Label="Фамилия" Required For="@(() => CreateEmployee!.LastName)" />
					</MudItem>
					<MudItem xs="12" sm="6">
						<MudTextField @bind-Value="CreateEmployee!.Name" Label="Имя" Required For="@(() => CreateEmployee!.Name)" />
					</MudItem>
					<MudItem xs="12" sm="6">
						<MudTextField @bind-Value="CreateEmployee!.Patronymic" Label="Отчество" />
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="CreateEmployee!.Email" Label="Email" Required For="@(() => CreateEmployee!.Email)" />
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="CreateEmployee!.PhoneNumber" Label="Номер телефона" Required For="@(() => CreateEmployee!.PhoneNumber)" />
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="CreateEmployee!.Address" Label="Адрес" Lines="2" Required For="@(() => CreateEmployee!.Address)" />
					</MudItem>
					<MudItem xs="12">
						<MudSelect T="RoleType" @bind-Value="CreateEmployee!.Role" Label="Роль" Required For="@(() => CreateEmployee!.Role)">
							@foreach (var role in Enum.GetValues<RoleType>())
							{
								<MudSelectItem Value="role">@role</MudSelectItem>
							}
						</MudSelect>
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="CreateEmployee!.Password" Label="Пароль" InputType="InputType.Password" Required For="@(() => CreateEmployee!.Password)" />
					</MudItem>
					<MudItem xs="12">
						<MudTextField @bind-Value="CreateEmployee!.ConfirmPassword" Label="Подтверждение пароля" InputType="InputType.Password" Required For="@(() => CreateEmployee!.ConfirmPassword)" />
					</MudItem>
				}
			</MudGrid>
		</EditForm>
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel">Отмена</MudButton>
		<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitForm" Disabled="@(!IsValid)">Сохранить</MudButton>
	</DialogActions>
</MudDialog>

@code {
	[CascadingParameter]
	IMudDialogInstance MudDialog { get; set; }

	[Parameter]
	public EmployeeUpdate? EditEmployee { get; set; }

	[Parameter]
	public CreateEmployee? CreateEmployee { get; set; }

	[Parameter]
	public bool IsEdit { get; set; }

	[Parameter]
	public EventCallback OnEmployeeSaved { get; set; }

	private EditForm? editForm;
	private bool IsValid => editForm?.EditContext?.Validate() ?? false;

	private async Task SubmitForm()
	{
		if(editForm != null && editForm.EditContext != null && editForm.EditContext.Validate())
		{
			await Save();
		}
	}

	private async Task Save()
	{
		try
		{
			if (IsEdit && EditEmployee != null)
			{
				await EmployeeService.UpdateEmployeeAsync(EditEmployee);
			}
			else
			{
				await EmployeeService.CreateEmployeeAsync(CreateEmployee);
			}

			await OnEmployeeSaved.InvokeAsync();
			MudDialog.Close(DialogResult.Ok(true));
		}
		catch (Exception)
		{
			NotificationService.ShowError($"Ошибка при сохранении сотрудника");
		}
	}

	void Cancel() => MudDialog.Cancel();
}
