<MudDialog>
	<TitleContent>
		<MudText Typo="Typo.h6">@Title</MudText>
	</TitleContent>
	<DialogContent>
		@if (!string.IsNullOrEmpty(Message))
		{
			<MudText Typo="Typo.body1">@Message</MudText>
		}
		@if(ConfirmationContent != null)
		{
			@ConfirmationContent
		}
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel">@NoText</MudButton>
		<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Confirm">@YesText</MudButton>
	</DialogActions>
</MudDialog>

@code {
	[CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

	[Parameter] public string Title { get; set; } = "Подтверждение";
	[Parameter] public string Message { get; set; } = string.Empty;
	[Parameter] public RenderFragment? ConfirmationContent { get; set; }
	[Parameter] public string YesText { get; set; } = "Да";
	[Parameter] public string NoText { get; set; } = "Нет";

	private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
	private void Cancel() => MudDialog.Cancel();
}
